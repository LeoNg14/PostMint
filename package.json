{
  "name": "postmint",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "yarn workspace @postmint/api dev",
    "dev:web": "yarn workspace @postmint/web dev",
    "build:api": "yarn workspace @postmint/api build",
    "build:web": "yarn workspace @postmint/web build"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
